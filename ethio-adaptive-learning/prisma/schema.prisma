generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
   output   = "../ERD.png"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(cuid())
  name                    String?
  username                String               @unique
  email                   String               @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String
  role                    UserRole             @default(STUDENT)
  grade                   StudentGrade?
  phoneNumber             String?
  createdAt               DateTime             @default(now())
  accounts                Account[]
  activityLogs            ActivityLog[]
  checkpointAttempts      CheckpointAttempt[]
  authoredConceptChunks   ConceptChunk[]       @relation("ConceptChunkAuthor")
  authoredContentSnippets ContentSnippet[]     @relation("ContentSnippetAuthor")
  authoredCourses         Course[]             @relation("CourseAuthor")
  examAttempts            ExamAttempt[]
  logs                    InteractionLog[]
  passwordResetTokens     PasswordResetToken[]
  practiceAttempts        PracticeAttempt[]
  authoredQuestions       Question[]           @relation("QuestionAuthor")
  sessions                Session[]
  tutorSessions           TutorSession[]
  masteries               UserMastery[]
  profile                 UserProfile?
  authoredWorkedExamples  WorkedExample[]      @relation("WorkedExampleAuthor")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  contentType String
  entityId    String
  entityTitle String?
  details     Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([contentType, entityId])
  @@index([createdAt])
}

model UserProfile {
  userId          String   @id
  totalXP         Int      @default(0)
  currentLevel    Int      @default(1)
  dailyStreak     Int      @default(0)
  lastLogin       DateTime @default(now())
  overallProgress Float    @default(0.0)
  user            User     @relation(fields: [userId], references: [id])
}

model Course {
  id              String               @id @default(cuid())
  slug            String               @unique
  title           String
  description     String?
  archivedAt      DateTime?
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  authorId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  author          User?                @relation("CourseAuthor", fields: [authorId], references: [id])
  units           Unit[]

  @@index([archivedAt])
  @@index([status])
}

model Unit {
  id              String               @id @default(cuid())
  slug            String
  title           String
  order           Int
  courseId        String
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  concepts        Concept[]
  course          Course               @relation(fields: [courseId], references: [id])

  @@unique([courseId, order])
  @@unique([courseId, slug])
  @@index([status])
}

model Concept {
  id                 String                @id @default(cuid())
  slug               String
  title              String
  description        String?
  unitId             String
  contentBody        String?
  contentBlocks      Json                  @default("[]")
  unlockThreshold    Float                 @default(0.90)
  status             CmsPublicationStatus  @default(PUBLISHED)
  publishedAt        DateTime?
  publishedById      String?
  unpublishedAt      DateTime?
  unpublishedById    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  pLo                Float                 @default(0.15)
  pT                 Float                 @default(0.10)
  pG                 Float                 @default(0.20)
  pS                 Float                 @default(0.10)
  decayLambda        Float                 @default(0.01)
  checkpointAttempts CheckpointAttempt[]
  unit               Unit                  @relation(fields: [unitId], references: [id])
  chunks             ConceptChunk[]
  closureDescendants ConceptClosure[]      @relation("ConceptClosureAncestor")
  closureAncestors   ConceptClosure[]      @relation("ConceptClosureDescendant")
  prerequisiteEdges  ConceptPrerequisite[] @relation("DependentConcept")
  dependentEdges     ConceptPrerequisite[] @relation("PrerequisiteConcept")
  examAttempts       ExamAttempt[]
  practiceAttempts   PracticeAttempt[]
  questions          Question[]
  tutorSessions      TutorSession[]
  userMasteries      UserMastery[]
  workedExamples     WorkedExample[]

  @@unique([unitId, title])
  @@unique([unitId, slug])
  @@index([status])
}

model ConceptPrerequisite {
  prerequisiteConceptId String
  dependentConceptId    String
  dependentConcept      Concept @relation("DependentConcept", fields: [dependentConceptId], references: [id], onDelete: Cascade)
  prerequisiteConcept   Concept @relation("PrerequisiteConcept", fields: [prerequisiteConceptId], references: [id], onDelete: Cascade)

  @@id([prerequisiteConceptId, dependentConceptId])
  @@index([dependentConceptId])
}

model ConceptChunk {
  id              String               @id @default(cuid())
  conceptId       String
  slug            String
  title           String
  bodyMd          String
  order           Int
  authorId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  author          User?                @relation("ConceptChunkAuthor", fields: [authorId], references: [id])
  concept         Concept              @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([conceptId, slug])
  @@unique([conceptId, order])
  @@index([status])
}

model WorkedExample {
  id              String               @id @default(cuid())
  conceptId       String
  slug            String
  title           String
  problemMd       String
  solutionMd      String
  order           Int
  authorId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  author          User?                @relation("WorkedExampleAuthor", fields: [authorId], references: [id])
  concept         Concept              @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([conceptId, slug])
  @@unique([conceptId, order])
  @@index([status])
}

model ConceptClosure {
  ancestorConceptId   String
  descendantConceptId String
  depth               Int
  ancestorConcept     Concept @relation("ConceptClosureAncestor", fields: [ancestorConceptId], references: [id], onDelete: Cascade)
  descendantConcept   Concept @relation("ConceptClosureDescendant", fields: [descendantConceptId], references: [id], onDelete: Cascade)

  @@id([ancestorConceptId, descendantConceptId])
  @@index([descendantConceptId])
}

model UserMastery {
  userId           String
  conceptId        String
  pMastery         Float         @default(0.15)
  lastAssessedAt   DateTime?
  nextReviewAt     DateTime?
  unlockedAt       DateTime?
  status           MasteryStatus @default(LOCKED)
  consecutiveFails Int           @default(0)
  concept          Concept       @relation(fields: [conceptId], references: [id])
  user             User          @relation(fields: [userId], references: [id])

  @@id([userId, conceptId])
  @@index([userId, nextReviewAt])
}

model Question {
  id                 String               @id @default(cuid())
  conceptId          String
  slug               String
  difficulty         DifficultyTier
  usage              QuestionUsage
  content            String
  correctAnswer      String
  distractors        Json?
  hintText           String?
  explanation        String?
  authorId           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  status             CmsPublicationStatus @default(PUBLISHED)
  publishedAt        DateTime?
  publishedById      String?
  unpublishedAt      DateTime?
  unpublishedById    String?
  checkpointAttempts CheckpointAttempt[]
  logs               InteractionLog[]
  practiceAttempts   PracticeAttempt[]
  author             User?                @relation("QuestionAuthor", fields: [authorId], references: [id])
  concept            Concept              @relation(fields: [conceptId], references: [id])

  @@unique([conceptId, slug])
  @@index([status])
}

model CmsDraft {
  id          String   @id @default(cuid())
  contentType String
  entityId    String
  data        Json
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentType, entityId])
  @@index([contentType])
  @@index([updatedAt])
}

model MediaAsset {
  id              String               @id @default(cuid())
  kind            MediaAssetKind
  title           String?
  alt             String?
  caption         String?
  publicId        String?              @unique
  url             String?
  width           Int?
  height          Int?
  bytes           Int?
  videoId         String?
  thumbnailUrl    String?
  createdById     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  usageLinks      ResourceUsage[]      @relation("MediaAssetUsage")

  @@index([kind])
  @@index([status])
  @@index([title])
}

model ContentSnippet {
  id              String               @id @default(cuid())
  slug            String               @unique
  title           String
  contentBlocks   Json                 @default("[]")
  authorId        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  author          User?                @relation("ContentSnippetAuthor", fields: [authorId], references: [id])
  usageLinks      ResourceUsage[]      @relation("ContentSnippetUsage")

  @@index([status])
  @@index([title])
}

model ResourceUsage {
  id               String          @id @default(cuid())
  mediaAssetId     String?
  contentSnippetId String?
  consumerType     String
  consumerId       String
  context          String?
  createdAt        DateTime        @default(now())
  contentSnippet   ContentSnippet? @relation("ContentSnippetUsage", fields: [contentSnippetId], references: [id], onDelete: Cascade)
  mediaAsset       MediaAsset?     @relation("MediaAssetUsage", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, consumerId, context])
  @@unique([contentSnippetId, consumerId, context])
  @@index([mediaAssetId])
  @@index([contentSnippetId])
  @@index([consumerId])
}

model PracticeAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model CheckpointAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model ExamAttempt {
  id               String      @id @default(cuid())
  userId           String
  conceptId        String
  pathway          PathwayType
  questionIds      Json
  submittedAnswers Json?
  questionCount    Int         @default(0)
  correctCount     Int?
  score            Float?
  timeSpentSec     Int?
  isPassed         Boolean?
  createdAt        DateTime    @default(now())
  completedAt      DateTime?
  concept          Concept     @relation(fields: [conceptId], references: [id])
  user             User        @relation(fields: [userId], references: [id])

  @@index([userId, conceptId, createdAt])
}

model InteractionLog {
  id             BigInt    @id @default(autoincrement())
  userId         String
  conceptId      String
  questionId     String?
  activityType   String
  isCorrect      Boolean?
  responseTimeMs Int?
  createdAt      DateTime  @default(now())
  question       Question? @relation(fields: [questionId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId, conceptId, createdAt])
  @@index([userId, questionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TutorSession {
  id        String         @id @default(cuid())
  userId    String
  conceptId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  TutorMessage[]
  concept   Concept        @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId])
}

model TutorMessage {
  id               String       @id @default(cuid())
  sessionId        String
  role             MessageRole
  content          String
  timestamp        DateTime     @default(now())
  tokens           Int?
  isFlagged        Boolean      @default(false)
  flagReason       String?
  retrievedContext Json?
  session          TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum UserRole {
  STUDENT
  COURSE_WRITER
  ADMIN
}

enum StudentGrade {
  MIDDLE_SCHOOL
  GRADE_9
  GRADE_10
  GRADE_11
  GRADE_12
  ABOVE
}

enum CmsPublicationStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum MediaAssetKind {
  IMAGE
  YOUTUBE_EMBED
  PHET_SIMULATION
}

enum MasteryStatus {
  LOCKED
  FRINGE
  IN_PROGRESS
  MASTERED
  REVIEW_NEEDED
}

enum DifficultyTier {
  EASY
  MEDIUM
  HARD
}

enum QuestionUsage {
  PRACTICE
  CHECKPOINT
  EXAM
}

enum PathwayType {
  LEARN
  CHALLENGE
}

enum MessageRole {
  STUDENT
  AI
}
