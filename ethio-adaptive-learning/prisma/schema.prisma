// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. IDENTITY & PROFILE (Subsystem 1)
// ==========================================

enum UserRole {
  STUDENT
  COURSE_WRITER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole  @default(STUDENT) // <--- Added Role
  createdAt     DateTime  @default(now())
  
  // Relations
  profile       UserProfile?
  accounts      Account[]
  sessions      Session[]
  masteries     UserMastery[]
  logs          InteractionLog[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]
  examAttempts  ExamAttempt[]

  // Audit Fields: Content created by this user (if they are a Course Writer)
  authoredCourses   Course[]   @relation("CourseAuthor")
  authoredQuestions Question[] @relation("QuestionAuthor")
}


model UserProfile {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id])
  totalXP          Int      @default(0)
  currentLevel     Int      @default(1)
  dailyStreak      Int      @default(0)
  lastLogin        DateTime @default(now())
  overallProgress  Float    @default(0.0) // Percentage 0-100
}

// ==========================================
// 2. KNOWLEDGE STRUCTURE & CMS (Subsystem 2 & 9)
// ==========================================

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  archivedAt  DateTime?
  units       Unit[]

  // Audit
  authorId    String?
  author      User?    @relation("CourseAuthor", fields: [authorId], references: [id])

  @@index([archivedAt])
}


model Unit {
  id        String    @id @default(cuid())
  title     String
  order     Int
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id])
  concepts  Concept[]

  @@unique([courseId, order])
}

model Concept {
  id             String   @id @default(cuid())
  title          String
  description    String?
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  
  // Instructional Content (Path A)
  contentBody    String?  @db.Text // Markdown/LaTeX content
  unlockThreshold Float   @default(0.90)
  
  // Default BKT Parameters for this Concept
  pLo            Float    @default(0.15) // Initial knowledge
  pT             Float    @default(0.10) // Probability of learning
  pG             Float    @default(0.20) // Probability of guess
  pS             Float    @default(0.10) // Probability of slip
  decayLambda    Float    @default(0.01) // Forgetting rate
  
  // KST: explicit DAG edges for maintainable prerequisite editing
  prerequisiteEdges ConceptPrerequisite[] @relation("DependentConcept")
  dependentEdges    ConceptPrerequisite[] @relation("PrerequisiteConcept")

  questions      Question[]
  userMasteries  UserMastery[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]
  examAttempts   ExamAttempt[]

  @@unique([unitId, title])
}

model ConceptPrerequisite {
  prerequisiteConceptId String
  dependentConceptId    String
  prerequisiteConcept   Concept @relation("PrerequisiteConcept", fields: [prerequisiteConceptId], references: [id], onDelete: Cascade)
  dependentConcept      Concept @relation("DependentConcept", fields: [dependentConceptId], references: [id], onDelete: Cascade)

  @@id([prerequisiteConceptId, dependentConceptId])
  @@index([dependentConceptId])
}

// ==========================================
// 3. MASTERY & RETENTION (Subsystem 3 & 4)
// ==========================================

enum MasteryStatus {
  LOCKED
  FRINGE
  IN_PROGRESS
  MASTERED
  REVIEW_NEEDED
}

model UserMastery {
  userId            String
  conceptId         String
  user              User          @relation(fields: [userId], references: [id])
  concept           Concept       @relation(fields: [conceptId], references: [id])

  // BKT Latent State
  pMastery          Float         @default(0.15) // P(L)
  lastAssessedAt    DateTime?
  nextReviewAt      DateTime?
  unlockedAt        DateTime?
  status            MasteryStatus @default(LOCKED)
  consecutiveFails  Int           @default(0)    // For Exam Policy logic

  @@id([userId, conceptId])
  @@index([userId, nextReviewAt])
}

// ==========================================
// 4. ASSESSMENT & DELIVERY (Subsystem 5)
// ==========================================

enum DifficultyTier {
  EASY
  MEDIUM
  HARD
}

enum QuestionUsage {
  PRACTICE
  CHECKPOINT
  EXAM
}

model Question {
  id            String         @id @default(cuid())
  conceptId     String
  concept       Concept        @relation(fields: [conceptId], references: [id])
  
  difficulty    DifficultyTier
  usage         QuestionUsage
  
  content       String         @db.Text 
  correctAnswer String
  distractors   Json?          
  hintText      String?        
  explanation   String?        @db.Text 
  
  // Audit: Track which writer created this question
  authorId      String?
  author        User?          @relation("QuestionAuthor", fields: [authorId], references: [id])

  logs          InteractionLog[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]
}

model PracticeAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?   @db.Text
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model CheckpointAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?   @db.Text
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model ExamAttempt {
  id              String       @id @default(cuid())
  userId          String
  conceptId       String
  user            User         @relation(fields: [userId], references: [id])
  concept         Concept      @relation(fields: [conceptId], references: [id])
  
  pathway         PathwayType
  questionIds     Json
  submittedAnswers Json?
  questionCount   Int          @default(0)
  correctCount    Int?
  score           Float?
  timeSpentSec    Int?
  isPassed        Boolean?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  @@index([userId, conceptId, createdAt])
}

enum PathwayType {
  LEARN
  CHALLENGE
}

// ==========================================
// 5. ANALYTICS & LOGGING (Subsystem 8)
// ==========================================

model InteractionLog {
  id             BigInt   @id @default(autoincrement())
  userId         String
  conceptId      String
  questionId     String?
  user           User     @relation(fields: [userId], references: [id])
  question       Question? @relation(fields: [questionId], references: [id])
  
  activityType   String   // e.g., "PRACTICE_QUESTION", "SOCRATIC_HINT"
  isCorrect      Boolean?
  responseTimeMs Int?
  createdAt      DateTime @default(now())

  @@index([userId, conceptId, createdAt])
  @@index([userId, questionId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
