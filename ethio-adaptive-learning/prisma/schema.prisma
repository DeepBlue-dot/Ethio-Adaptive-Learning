// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. IDENTITY & PROFILE (Subsystem 1)
// ==========================================

enum UserRole {
  STUDENT
  COURSE_WRITER
  ADMIN
}

enum StudentGrade {
  MIDDLE_SCHOOL
  GRADE_9
  GRADE_10
  GRADE_11
  GRADE_12
  ABOVE
}

enum CmsPublicationStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum MediaAssetKind {
  IMAGE
  YOUTUBE_EMBED
  PHET_SIMULATION
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole  @default(STUDENT) // <--- Added Role
  grade         StudentGrade?
  phoneNumber   String?
  createdAt     DateTime  @default(now())
  
  // Relations
  profile       UserProfile?
  accounts      Account[]
  sessions      Session[]
  masteries     UserMastery[]
  logs          InteractionLog[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]
  examAttempts  ExamAttempt[]
  tutorSessions TutorSession[]

  // Audit Fields: Content created by this user (if they are a Course Writer)
  authoredCourses        Course[]        @relation("CourseAuthor")
  authoredQuestions      Question[]      @relation("QuestionAuthor")
  authoredConceptChunks  ConceptChunk[]  @relation("ConceptChunkAuthor")
  authoredWorkedExamples WorkedExample[] @relation("WorkedExampleAuthor")
  authoredContentSnippets ContentSnippet[] @relation("ContentSnippetAuthor")
  passwordResetTokens    PasswordResetToken[]
  activityLogs           ActivityLog[]
}

model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  action        String   // CREATE, UPDATE, DELETE, PUBLISH, UNPUBLISH
  contentType   String
  entityId      String
  entityTitle   String?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([contentType, entityId])
  @@index([createdAt])
}


model UserProfile {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id])
  totalXP          Int      @default(0)
  currentLevel     Int      @default(1)
  dailyStreak      Int      @default(0)
  lastLogin        DateTime @default(now())
  overallProgress  Float    @default(0.0) // Percentage 0-100
}

// ==========================================
// 2. KNOWLEDGE STRUCTURE & CMS (Subsystem 2 & 9)
// ==========================================

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  archivedAt  DateTime?
  units       Unit[]

  // Editorial lifecycle
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?

  // Audit
  authorId    String?
  author      User?    @relation("CourseAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([archivedAt])
  @@index([status])
}


model Unit {
  id        String    @id @default(cuid())
  slug      String
  title     String
  order     Int
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id])
  concepts  Concept[]
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, order])
  @@unique([courseId, slug])
  @@index([status])
}

model Concept {
  id             String   @id @default(cuid())
  slug           String
  title          String
  description    String?
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  
  // Instructional Content (Path A)
  contentBody    String?  @db.Text // Markdown/LaTeX content
  contentBlocks  Json     @default("[]")
  unlockThreshold Float   @default(0.90)
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Default BKT Parameters for this Concept
  pLo            Float    @default(0.15) // Initial knowledge
  pT             Float    @default(0.10) // Probability of learning
  pG             Float    @default(0.20) // Probability of guess
  pS             Float    @default(0.10) // Probability of slip
  decayLambda    Float    @default(0.01) // Forgetting rate
  
  // KST: explicit DAG edges for maintainable prerequisite editing
  prerequisiteEdges ConceptPrerequisite[] @relation("DependentConcept")
  dependentEdges    ConceptPrerequisite[] @relation("PrerequisiteConcept")
  chunks           ConceptChunk[]
  workedExamples   WorkedExample[]
  closureAncestors   ConceptClosure[] @relation("ConceptClosureDescendant")
  closureDescendants ConceptClosure[] @relation("ConceptClosureAncestor")

  questions      Question[]
  userMasteries  UserMastery[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]
  examAttempts   ExamAttempt[]
  tutorSessions  TutorSession[]

  @@unique([unitId, title])
  @@unique([unitId, slug])
  @@index([status])
}

model ConceptPrerequisite {
  prerequisiteConceptId String
  dependentConceptId    String
  prerequisiteConcept   Concept @relation("PrerequisiteConcept", fields: [prerequisiteConceptId], references: [id], onDelete: Cascade)
  dependentConcept      Concept @relation("DependentConcept", fields: [dependentConceptId], references: [id], onDelete: Cascade)

  @@id([prerequisiteConceptId, dependentConceptId])
  @@index([dependentConceptId])
}

model ConceptChunk {
  id        String   @id @default(cuid())
  conceptId String
  slug      String
  title     String
  bodyMd    String   @db.Text
  order     Int
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  concept   Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  author    User?    @relation("ConceptChunkAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([conceptId, slug])
  @@unique([conceptId, order])
  @@index([status])
}

model WorkedExample {
  id         String   @id @default(cuid())
  conceptId  String
  slug       String
  title      String
  problemMd  String   @db.Text
  solutionMd String   @db.Text
  order      Int
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?
  concept    Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  author     User?    @relation("WorkedExampleAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([conceptId, slug])
  @@unique([conceptId, order])
  @@index([status])
}

model ConceptClosure {
  ancestorConceptId   String
  descendantConceptId String
  depth               Int
  ancestorConcept     Concept @relation("ConceptClosureAncestor", fields: [ancestorConceptId], references: [id], onDelete: Cascade)
  descendantConcept   Concept @relation("ConceptClosureDescendant", fields: [descendantConceptId], references: [id], onDelete: Cascade)

  @@id([ancestorConceptId, descendantConceptId])
  @@index([descendantConceptId])
}

// ==========================================
// 3. MASTERY & RETENTION (Subsystem 3 & 4)
// ==========================================

enum MasteryStatus {
  LOCKED
  FRINGE
  IN_PROGRESS
  MASTERED
  REVIEW_NEEDED
}

model UserMastery {
  userId            String
  conceptId         String
  user              User          @relation(fields: [userId], references: [id])
  concept           Concept       @relation(fields: [conceptId], references: [id])

  // BKT Latent State
  pMastery          Float         @default(0.15) // P(L)
  lastAssessedAt    DateTime?
  nextReviewAt      DateTime?
  unlockedAt        DateTime?
  status            MasteryStatus @default(LOCKED)
  consecutiveFails  Int           @default(0)    // For Exam Policy logic

  @@id([userId, conceptId])
  @@index([userId, nextReviewAt])
}

// ==========================================
// 4. ASSESSMENT & DELIVERY (Subsystem 5)
// ==========================================

enum DifficultyTier {
  EASY
  MEDIUM
  HARD
}

enum QuestionUsage {
  PRACTICE
  CHECKPOINT
  EXAM
}

model Question {
  id            String         @id @default(cuid())
  conceptId     String
  slug          String
  concept       Concept        @relation(fields: [conceptId], references: [id])
  
  difficulty    DifficultyTier
  usage         QuestionUsage
  
  content       String         @db.Text 
  correctAnswer String
  distractors   Json?          
  hintText      String?        
  explanation   String?        @db.Text 
  
  // Audit: Track which writer created this question
  authorId      String?
  author        User?          @relation("QuestionAuthor", fields: [authorId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?

  logs          InteractionLog[]
  practiceAttempts   PracticeAttempt[]
  checkpointAttempts CheckpointAttempt[]

  @@unique([conceptId, slug])
  @@index([status])
}

model CmsDraft {
  id          String   @id @default(cuid())
  contentType String
  entityId    String
  data        Json
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentType, entityId])
  @@index([contentType])
  @@index([updatedAt])
}

model MediaAsset {
  id           String @id @default(cuid())
  kind         MediaAssetKind
  title        String?
  alt          String?
  caption      String?
  publicId     String? @unique
  url          String?
  width        Int?
  height       Int?
  bytes        Int?
  videoId      String?
  thumbnailUrl String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?

  usageLinks   ResourceUsage[] @relation("MediaAssetUsage")

  @@index([kind])
  @@index([status])
  @@index([title])
}

model ContentSnippet {
  id            String @id @default(cuid())
  slug          String @unique
  title         String
  contentBlocks Json   @default("[]")
  authorId      String?
  author        User?  @relation("ContentSnippetAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  status          CmsPublicationStatus @default(PUBLISHED)
  publishedAt     DateTime?
  publishedById   String?
  unpublishedAt   DateTime?
  unpublishedById String?

  usageLinks    ResourceUsage[] @relation("ContentSnippetUsage")

  @@index([status])
  @@index([title])
}

model ResourceUsage {
  id           String @id @default(cuid())
  
  // The resource being used
  mediaAssetId   String?
  mediaAsset     MediaAsset? @relation("MediaAssetUsage", fields: [mediaAssetId], references: [id], onDelete: Cascade)
  contentSnippetId String?
  contentSnippet   ContentSnippet? @relation("ContentSnippetUsage", fields: [contentSnippetId], references: [id], onDelete: Cascade)
  
  // The consumer of the resource
  consumerType String // "CONCEPT", "QUESTION", "CONTENT_SNIPPET"
  consumerId   String
  
  // Metadata
  context      String? // e.g. "contentBlocks[0]"
  createdAt    DateTime @default(now())

  @@index([mediaAssetId])
  @@index([contentSnippetId])
  @@index([consumerId])
  @@unique([mediaAssetId, consumerId, context])
  @@unique([contentSnippetId, consumerId, context])
}

model PracticeAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?   @db.Text
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model CheckpointAttempt {
  id             String    @id @default(cuid())
  userId         String
  conceptId      String
  questionId     String
  selectedAnswer String?   @db.Text
  isCorrect      Boolean?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept        Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, conceptId, createdAt])
  @@index([questionId])
}

model ExamAttempt {
  id              String       @id @default(cuid())
  userId          String
  conceptId       String
  user            User         @relation(fields: [userId], references: [id])
  concept         Concept      @relation(fields: [conceptId], references: [id])
  
  pathway         PathwayType
  questionIds     Json
  submittedAnswers Json?
  questionCount   Int          @default(0)
  correctCount    Int?
  score           Float?
  timeSpentSec    Int?
  isPassed        Boolean?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  @@index([userId, conceptId, createdAt])
}

enum PathwayType {
  LEARN
  CHALLENGE
}

// ==========================================
// 5. ANALYTICS & LOGGING (Subsystem 8)
// ==========================================

model InteractionLog {
  id             BigInt   @id @default(autoincrement())
  userId         String
  conceptId      String
  questionId     String?
  user           User     @relation(fields: [userId], references: [id])
  question       Question? @relation(fields: [questionId], references: [id])
  
  activityType   String   // e.g., "PRACTICE_QUESTION", "SOCRATIC_HINT"
  isCorrect      Boolean?
  responseTimeMs Int?
  createdAt      DateTime @default(now())

  @@index([userId, conceptId, createdAt])
  @@index([userId, questionId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 6. AI SOCRATIC TUTORING (Subsystem 6)
// ==========================================

model TutorSession {
  id          String         @id @default(cuid())
  userId      String
  conceptId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept     Concept        @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  messages    TutorMessage[]
  
  @@index([userId, conceptId])
}

model TutorMessage {
  id             String       @id @default(cuid())
  sessionId      String
  role           MessageRole
  content        String       @db.Text
  timestamp      DateTime     @default(now())
  
  // Metadata for RAG and Guardrails
  tokens         Int?         
  isFlagged      Boolean      @default(false)
  flagReason     String?
  retrievedContext Json?      // Store context used for this response
  
  session        TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum MessageRole {
  STUDENT
  AI
}
